rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function caller() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && caller().role == 'ADMIN';
    }

    function isVerifiedDriver() {
      return isSignedIn() && caller().role == 'DRIVER' && caller().is_verified == true;
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    match /users/{userId} {
      allow get: if isSelf(userId) || isAdmin();
      allow list: if isAdmin();

      allow create: if isSelf(userId)
        && request.resource.data.id == userId
        && request.resource.data.role in ['CLIENT', 'DRIVER']
        && request.resource.data.is_verified == false
        && request.resource.data.wallet_balance == 0
        && request.resource.data.status == 'ACTIVE'
        && request.resource.data.rating_avg == 0
        && request.resource.data.rating_count == 0;

      allow update: if
        (isSelf(userId) && changedKeys().hasOnly(
          ['full_name', 'phone', 'is_online', 'last_status_update',
           'fcm_token', 'vehicle', 'current_trip_id']))
        || (isAdmin() && changedKeys().hasOnly(['is_verified', 'status']));

      allow delete: if false;

      match /kyc_documents/{docId} {
        allow read: if isSelf(userId) || isAdmin();

        allow create: if isSelf(userId)
          && request.resource.data.status == 'PENDING'
          && request.resource.data.id == docId
          && request.resource.data.type in
             ['ID_FRONT', 'ID_BACK', 'DRIVER_LICENSE', 'SOAT',
              'VEHICLE_TECH_REVIEW', 'VEHICLE_REGISTRATION_CARD'];

        allow update: if
          (isSelf(userId)
            && request.resource.data.status == 'PENDING'
            && changedKeys().hasOnly(['image_url', 'status', 'rejection_reason']))
          || (isAdmin()
            && changedKeys().hasOnly(['status', 'rejection_reason'])
            && request.resource.data.status in ['APPROVED', 'REJECTED']);

        allow delete: if false;
      }
    }

    match /quotes/{quoteId} {
      // Clients can read their own quotes to display the QuoteScreen.
      allow read: if isSignedIn() && resource.data.client_id == request.auth.uid;
      // Cloud Functions only — clients cannot create or modify quotes.
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /trips/{tripId} {
      function isParticipant() {
        return isSignedIn()
          && (resource.data.client_id == request.auth.uid
              || resource.data.driver_id == request.auth.uid);
      }

      // Drivers may read REQUESTED trips to display the available list;
      // all other reads require being a participant or admin.
      allow read: if isParticipant() || isAdmin()
        || (isVerifiedDriver() && resource.data.status == 'REQUESTED');

      // Trip creation is now handled exclusively by the requestTrip Cloud Function.
      allow create: if false;

      allow update: if
        // (1) The assigned driver advances the lifecycle one hop at a time.
        (resource.data.driver_id == request.auth.uid
          && changedKeys().hasOnly(['status', 'completed_at'])
          && ((resource.data.status == 'ACCEPTED'        && request.resource.data.status == 'ON_WAY')
           || (resource.data.status == 'ON_WAY'          && request.resource.data.status == 'ARRIVED_PICKUP')
           || (resource.data.status == 'ARRIVED_PICKUP'  && request.resource.data.status == 'IN_PROGRESS')
           || (resource.data.status == 'IN_PROGRESS'     && request.resource.data.status == 'COMPLETED')))
        // (2) The assigned driver streams location while the trip is active.
        || (resource.data.driver_id == request.auth.uid
          && resource.data.status in ['ACCEPTED', 'ON_WAY', 'ARRIVED_PICKUP', 'IN_PROGRESS']
          && changedKeys().hasOnly(['driver_last_lat', 'driver_last_lng', 'last_location_update']))
        // (3) The client may cancel before pickup.
        || (resource.data.client_id == request.auth.uid
          && resource.data.status in ['REQUESTED', 'OFFERED', 'ACCEPTED']
          && request.resource.data.status == 'CANCELLED_CLIENT'
          && changedKeys().hasOnly(['status', 'cancelled_by']));

      allow delete: if false;
    }

    match /trip_offers/{offerId} {
      // Drivers can only read their own offers.
      allow read: if isSignedIn() && resource.data.driver_id == request.auth.uid;
      // Cloud Functions only — no direct writes from clients.
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /dispatch_locks/{tripId} {
      // Cloud Functions only.
      allow read: if false;
      allow write: if false;
    }

    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
